{
   "action": {
      "default_popup": "popup.html",
      "default_title": "Wordtune"
   },
   "background": {
      "service_worker": "background.js"
   },
   "browser_specific_settings": {
      "gecko": {
         "id": "support@wordtune.com",
         "strict_min_version": "58.0"
      }
   },
   "content_scripts": [ {
      "js": [ "content-scripts/browserDetector.js", "content-scripts/content.js", "content-scripts/read.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content-scripts/enableCanvasAnnotations.js" ],
      "matches": [ "*://docs.google.com/document/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "content-scripts/wordtuneExtensionInstalled.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start",
      "world": "MAIN"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "default_locale": "en",
   "description": "Unlock your potential with Wordtune's free AI writer – paraphrase, rewrite, translate, fix grammar, and more.",
   "externally_connectable": {
      "matches": [ "https://app.wordtune.com/*", "https://www.wordtune.com/*" ]
   },
   "host_permissions": [ "*://*/*", "https://*.wordtune.com/*" ],
   "icons": {
      "128": "/icon/128.png",
      "16": "/icon/16.png",
      "32": "/icon/32.png",
      "48": "/icon/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Wordtune: AI Paraphrasing and Grammar Tool",
   "optional_permissions": [ "clipboardRead", "clipboardWrite" ],
   "permissions": [ "http://*/*", "https://*/*", "cookies", "storage", "scripting", "tabs", "sidePanel" ],
   "short_name": "Wordtune",
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "9.19.0",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "asset/**/*.woff", "assets/**/*.woff2", "assets/**/*.png", "assets/**/*.svg", "assets/**/*.jpg", "assets/**/*.gif", "assets/**/*.css", "chunks/*.js", "content-scripts/*.js" ]
   }, {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "content-scripts/content.css" ]
   }, {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "content-scripts/read.css" ]
   } ]
}
